# ─── LLM Backend ───────────────────────────────────────────────────────────────
# Options: "ollama" | "huggingface" | "stub"
LLM_BACKEND=ollama

# Ollama settings (if LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# HuggingFace settings (if LLM_BACKEND=huggingface)
HF_MODEL=google/flan-t5-base

# ─── Embedding Model ────────────────────────────────────────────────────────────
# Options: all-MiniLM-L6-v2 | multi-qa-MiniLM-L6-cos-v1 | BAAI/bge-small-en | BAAI/bge-base-en
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Vector Store ───────────────────────────────────────────────────────────────
# Options: faiss | chroma
VECTOR_STORE=faiss

# ─── Retrieval Settings ─────────────────────────────────────────────────────────
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50
USE_RERANKER=true
USE_HYBRID=true
HYBRID_ALPHA=0.5          # weight for vector score vs BM25 (0=BM25 only, 1=vector only)

# ─── Reranker Model ─────────────────────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── Database ───────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=data/rag_eval.db

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
